{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AutoShorts",
  "version": "0.1.0",
  "identifier": "com.autoshorts.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AutoShorts",
        "width": 1280,
        "height": 840,
        "minWidth": 1040,
        "minHeight": 700
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
